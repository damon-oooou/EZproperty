# 复制本文件为 .env.local 并填入真实值(.env.local 不进 git)。

# Google 登录:Google Cloud Console 申请的 OAuth Client ID。
# 后端用同一个值,通过环境变量 GOOGLE_CLIENT_ID 配置。
# 不配置则登录页不显示 Google 按钮,密码登录不受影响。
VITE_GOOGLE_CLIENT_ID=

# v0.6:后端 API 地址(不含 /api 后缀)。本地开发不用配,默认 http://localhost:8080。
# Vercel 部署时设置:先用 Railway 生成域名,正式域名生效后换 https://api.<domain>
VITE_API_BASE_URL=

# v0.6:Sentry 前端 DSN。不配置 = 不初始化,本地开发不用配。
VITE_SENTRY_DSN=
